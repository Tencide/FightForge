# Copy this file to .env.fly in the same folder (backend/) and fill in. Never commit .env.fly.
# Then: pwsh -File scripts/apply-fly-secrets.ps1   (from backend/)

NODE_ENV=production
PORT=5000

DB_HOST=your-mysql-host.example.com
DB_PORT=3306
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=fightforge

JWT_SECRET=generate-with-node-e-console-log-crypto-randomBytes

# After Vercel deploy — exact origin(s), comma-separated, no spaces after commas:
CORS_ORIGIN=https://your-app.vercel.app
