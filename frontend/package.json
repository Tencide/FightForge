{
  "name": "fightforge-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "node scripts/apply-vercel-api-rewrite.mjs && vite build",
    "build:mobile": "cross-env CAPACITOR=1 VITE_API_BASE=https://fightforge-api.fly.dev vite build",
    "cap:sync": "npm run build:mobile && node scripts/apply-capacitor-live-url.mjs && npx cap sync",
    "cap:ios": "npx cap open ios",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/core": "^7.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.6.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.2.0",
    "@capacitor/ios": "^7.2.0",
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^5.4.11",
    "vitest": "^3.2.4"
  }
}
