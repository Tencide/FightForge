# Frontend environment variables.
# Only variables prefixed with VITE_ are bundled into the client.
#
# Local dev: leave VITE_API_BASE empty. The Vite dev server proxies /api
#            to VITE_PROXY_TARGET (default http://127.0.0.1:5000).
# Production (Vercel): set VITE_API_BASE to the absolute URL of your
#            deployed backend, e.g. https://fightforge-api.up.railway.app

VITE_API_BASE=

# Only used by the Vite dev server proxy (npm run dev). Has no effect in
# production builds.
VITE_PROXY_TARGET=http://127.0.0.1:5000

# Show sample-account quick-fill on Login + sample-credentials callout on Home.
# Use only on trusted local machines (never enable on a public production site).
#
#   true  -> visible (optional local dev)
#   false -> hidden (default for releases and public hosting)
VITE_SHOW_DEMO_ACCOUNTS=false
